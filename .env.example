# Knowledge base paths
# Defaults to ./wiki/wiki and ./wiki/raw relative to the project directory
# WIKI_PATH=/path/to/your/wiki
# RAW_PATH=/path/to/your/raw

# HTTP port
# PORT=9090

# Single-user login (optional). If both are set, a password-protected login page is enabled.
# AUTH_USERNAME=admin
# AUTH_PASSWORD=changeme

# LLM provider: "anthropic" (default) or "openai"
LLM_PROVIDER=openai

# Anthropic settings (used when LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=your_api_key_here
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6

# OpenAI settings (used when LLM_PROVIDER=openai)
OPENAI_API_KEY=your_api_key_here
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o

# Scheduled ingest: cron expression (default: every 30 min)
INGEST_CRON=*/30 * * * *

# Set to "false" to disable the scheduler on startup
INGEST_ENABLED=true

# Health check scheduler cron expression (default: daily at midnight)
# LINT_CRON=0 0 * * *

# Set to "true" to enable the health check scheduler on startup (default: false)
# LINT_ENABLED=false

# Comma-separated top-level directories under raw/ to exclude from scanning
# INGEST_EXCLUDE=notes,assets

# Language for generated wiki content: zh (Chinese) | en (English) | auto (follow source)
INGEST_LANG=zh

# ── Ingest quality tuning ────────────────────────────────────────────────────

# Max characters of source content sent to the LLM (default: 50000)
# Unit: characters (≈50k chars = ~30k tokens for Chinese, ~12k tokens for English)
# Raise for long documents; very large values increase cost and latency
# INGEST_MAX_CHARS=50000

# Max tokens the LLM can generate per ingest call (default: 8192)
# Unit: output tokens. Raise if the LLM produces truncated pages or too few pages
# INGEST_MAX_TOKENS=8192

# Characters of index.md passed as cross-linking context (default: 3000)
# Unit: characters. Raise as the knowledge base grows for better cross-linking
# INGEST_INDEX_CHARS=3000

# Language for query answers: zh (Chinese) | en (English) | bilingual (中英双语)
QUERY_LANG=zh

# ── Query quality tuning ─────────────────────────────────────────────────────

# Number of wiki pages passed to the LLM as context (default: 10)
# Unit: pages. Lower = faster and less noise; raise for broad or cross-topic questions
# QUERY_TOP_K=10

# Characters taken from each page (default: 8000)
# Unit: characters. Raise if pages are long and answers feel incomplete
# QUERY_PAGE_CHARS=8000

# Minimum relevance score for a page to be included (default: 0)
# Unit: dimensionless score (keyword hits × token length + bigram matches × 0.4)
# 0 = any keyword hit qualifies; raise to 5–20 on large knowledge bases
# QUERY_MIN_SCORE=0

# Maximum tokens in the LLM answer (default: 2048)
# Unit: output tokens. Raise for more detailed responses
# QUERY_MAX_TOKENS=2048

# Redis (for Q&A history). Defaults to localhost:6379. Gracefully disabled if unavailable.
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=
